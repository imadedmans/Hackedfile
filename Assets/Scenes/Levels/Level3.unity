  m_Text: "temporal void FrameUpdate()\n{\n   //the mock script still needs to be
    finished\n    OnRun(\"Start\")<new void(\"Debug\", variable[recieve.outer = 'r'])>;\n   
    if(variable[r].null == objs debugF.Length)\n    {\n        Console.Log(\"debug
    run successful\");\n        debug(currentLvl) = LOCALEXECUTABLE(OVERRIDE = 11);\n       
    debug.pargam<status(relaunch)>.enabled = true;\n    }\n  \n    On(debug<status>.enabled
    = true)\n    {\n        RUNCONSTANT<Main(strict.CONSTANT)>();\n    }\n    Locator.FindLocation(level);\n   
    RUNCONSTANT<>();\n}\n\n    constant void Debug()\n    {  \n\n    \n    if(debugableWall.groupCollection[i
    = 0], screen.Number = 3)\n    {\n        debugableWall.enabled =\n    }\nif(debugableWall.groupCollection[i
    = 1], screen.Number = 4)\n    {\n        debugableWall.enabled =\n    }\nif(debugableWall.groupCollection[i
    = 2], screen.Number = 6)\n    {\n        debugableWall.enabled =\n    }\nif(debugableWall.groupCollection[i
    = 3], screen.Number = 7)\n    {\n        debugableWall.enabled =\n    }\n   
    \n}\n\nprivate void CompleteLvl()\n    {\n         ONSTART.LOCAL = int win.GameObject.Goal(Internal.GetObject);\n        
    RUNCONSTANTVOID.Goal<pargam(Win())>;\n         if(level == 3, SOURCE.EXECUTABLE(null))\n        
    {\n             RECIEVE<new variable(.taj.XEngine), new bool(external.taj.System)>(collection.entity
    = enabled);\n             new debug = EXECUTABLE(OVERRIDE = 07);\n            
    RUNCONSTANT.debug<pargam(Window().edittable)>;\n         }\n    }"
